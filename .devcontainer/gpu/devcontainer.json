{
    "name": "GPU Dev Container (Project Forge)",
    // Dockerfileからビルド
    "build": {
        "dockerfile": "Dockerfile",
        "context": "../.."
    },
    // ワークスペースのマウント設定
    "workspaceFolder": "/workspace",
    "mounts": [
        "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached"
    ],
    // time zoneの変更
    "containerEnv": {
        "TZ": "Asia/Tokyo"
    },
    // GPUを割り当てるための引数を追加
    "remoteUser": "root",
    "runArgs": [
        "--gpus=all",
        "--memory=64g",
        "--memory-swap=64g",
        "--shm-size=2g"
    ],
    // VS Codeの便利な設定
    "customizations": {
        "vscode": {
            "settings": {
                // コンテナ内で使用するPythonインタプリタを固定
                "python.defaultInterpreterPath": "/opt/conda/bin/python",
                // ターミナル起動時に自動でconda activateを実行
                "python.terminal.activateEnvironment": true,
                "python.formatting.provider": "black",
                "python.linting.enabled": true
            },
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "ms-toolsai.jupyter"
            ]
        }
    },
    // コンテナ内のポートを手元のPCに転送
    "forwardPorts": [
        8888,
        8787
    ],
    "portsAttributes": {
        "8888": {
            "label": "JupyterLab"
        },
        "8787": {
            "label": "Dask Dashboard"
        }
    }
}