{
    "name": "RAPIDS Dev Container",
    // 1. 成功したイメージを正確に指定
    "image": "rapidsai/base:25.08-cuda12.0-py3.11",
    // 2. GPUを割り当てるための引数を追加
    "runArgs": [
        "--gpus=all",
        "--shm-size=2g" // 共有メモリを2GBに増量
    ],
    // VS Codeの便利な設定（Python拡張機能の自動インストールなど）
    "customizations": {
        "vscode": {
            "settings": {
                // コンテナ内で使用するPythonインタプリタを固定
                "python.defaultInterpreterPath": "/opt/conda/bin/python",
                // ターミナル起動時に自動でconda activateを実行
                "python.terminal.activateEnvironment": true,
                "python.formatting.provider": "black",
                "python.linting.enabled": true
            },
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance", // 高機能なコード補完
                "ms-toolsai.jupyter" // Jupyter Notebook連携
            ]
        }
    },
    // コンテナ内のポートを手元のPCに転送
    "forwardPorts": [
        8888,
        8787
    ],
    "portsAttributes": {
        "8888": {
            "label": "JupyterLab"
        },
        "8787": {
            "label": "Dask Dashboard"
        }
    },
    // コンテナ初回起動時のみ実行されるコマンド
    // 例: pipで追加パッケージをインストールする
    "postCreateCommand": "pip install --user -r requirements.txt && echo 'export PATH=\"$HOME/.local/bin:$PATH\"' >> ~/.bashrc",
    // GitHub CLIの追加
    "features": {
        "ghcr.io/devcontainers/features/github-cli:1": {}
    }
}