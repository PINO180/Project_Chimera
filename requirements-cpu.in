# requirements-cpu.in - 安定版 (Stable Version)

# ----------------------------------------------------
# 核心的な互換性の基盤 (Core Compatibility Foundation)
# ----------------------------------------------------
# NumPy 2.0系は多くのライブラリと互換性がないため、1.x系に固定する
numpy<2.0

# ----------------------------------------------------
# 主要な科学技術計算・データ処理ライブラリ
# ----------------------------------------------------
scipy
sympy
psutil
memory-profiler
pyarrow
polars
pathos

# ----------------------------------------------------
# Daskエコシステム
# ----------------------------------------------------
# dask[complete]は依存関係を複雑化させるため、主要コンポーネントを明示的に指定
dask
distributed
dask-ml
dask-lightgbm

# ----------------------------------------------------
# 統計・時系列解析
# ----------------------------------------------------
statsmodels
pmdarima
arch
hmmlearn
tslearn

# ----------------------------------------------------
# 機械学習
# ----------------------------------------------------
xgboost
scikit-learn
shap
# lightgbmはdask-lightgbmの依存関係に含まれるため、ここでは不要

# ----------------------------------------------------
# PyTorch & TensorFlow
# ----------------------------------------------------
torch
torchvision
tensorflow

# ----------------------------------------------------
# その他Project Forgeで必要なライブラリ
# ----------------------------------------------------
PyWavelets
dcor
entropy
MFDFA
nolds
PyCausality
EMD-signal
emd
tqdm
pyzmq

# ----------------------------------------------------
# 開発用
# ----------------------------------------------------
jupyterlab>=4.0,<5.0